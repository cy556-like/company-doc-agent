{
    "name": "docagent-android",
    "version": "1.0.0",
    "description": "DocAgent 企业文档智能平台 - Android App",
    "main": "index.js",
    "scripts": {
        "build": "echo 'No build step needed - using static files from parent directory'",
        "cap:init": "npx cap init DocAgent com.docagent.app --web-dir=../app/static",
        "cap:add:android": "npx cap add android",
        "cap:sync": "npx cap sync",
        "cap:open": "npx cap open android",
        "cap:run:android": "npx cap run android",
        "android:build:debug": "npx cap sync && npx cap run android",
        "android:build:release": "npx cap sync && cd android && ./gradlew assembleRelease && cd .."
    },
    "dependencies": {
        "@capacitor/android": "^6.0.0",
        "@capacitor/core": "^6.0.0",
        "@capacitor/app": "^6.0.0",
        "@capacitor/haptics": "^6.0.0",
        "@capacitor/keyboard": "^6.0.0",
        "@capacitor/network": "^6.0.0",
        "@capacitor/splash-screen": "^6.0.0",
        "@capacitor/status-bar": "^6.0.0"
    },
    "devDependencies": {
        "@capacitor/cli": "^6.0.0"
    },
    "keywords": ["docagent", "android", "capacitor"],
    "author": "DocAgent Team",
    "license": "MIT"
}
